# HZ Trading App — Environment Variables

# API-Sports Basketball key (required for live data)
API_SPORTS_KEY=your_api_sports_key_here

# --- Google Sheets Integration (optional, for H2H seasonal cache) ---

# The ID of your Google Sheet (from the URL: .../spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Tab name in the sheet (default: h2h_2025_2026)
GOOGLE_SHEETS_TAB=h2h_2025_2026

# Service account credentials — one of three formats:
#   1. File path:       /path/to/service_account.json
#   2. Base64 JSON:     base64-encoded content of the JSON key file
#   3. Raw JSON string: {"type":"service_account","project_id":...}
GOOGLE_CREDENTIALS_JSON=/path/to/service_account.json
